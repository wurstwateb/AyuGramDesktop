ivEditorToolbarOverflowIconOver: icon {{ "title_menu_dots", menuIconColor, point(0px, -2px) }};
ivEditorToolbarBoldIcon: icon {{ "menu/rich/bold-24x24", menuIconColor }};
ivEditorToolbarItalicIcon: icon {{ "menu/rich/italic-24x24", menuIconColor }};
