ivEditorBottomSend: SendButton(historySend) {
	sendIconPosition: point(8px, 8px);
	sendIconFillPadding: 8px;
	inner: IconButton(historyAttach) {
		width: ivEditorBottomCircleSize;
		height: ivEditorBottomCircleSize;
		icon: icon {{ "menu/rich/send-24x24", windowFgActive }};
		iconOver: icon {{ "menu/rich/send-24x24", windowFgActive }};
		rippleAreaSize: ivEditorBottomCircleSize;
		rippleAreaPosition: point(0px, 0px);
	}
	stars: RoundButton(defaultActiveButton) {
		height: ivEditorBottomCircleSize;
		padding: margins(6px, 0px, 10px, 0px);
		textTop: 11px;
		width: -8px;
	}
	sendIconFg: windowFgActive;
}
ivEditorBottomSaveSend: SendButton(historySend) {
	sendIconPosition: point(8px, 8px);
	sendIconFillPadding: 8px;
	inner: IconButton(historyAttach) {
		width: ivEditorBottomCircleSize;
		height: ivEditorBottomCircleSize;
		icon: icon {{ "menu/rich/save-24x24", windowFgActive }};
		iconOver: icon {{ "menu/rich/save-24x24", windowFgActive }};
		rippleAreaSize: ivEditorBottomCircleSize;
		rippleAreaPosition: point(0px, 0px);
	}
	sendIconFg: windowFgActive;
}
