	width: ivEditorToolbarButtonSize;
	height: ivEditorToolbarButtonSize;
	iconPosition: point(-1px, -1px);
	rippleAreaPosition: point(0px, 0px);
	rippleAreaSize: ivEditorToolbarButtonSize;
